---
const siteUrl = 'https://ehsanulhaquesiam.netlify.app';
---

<!doctype html>
<html lang="en" style="background:#05060A">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>404 · Page Not Found | Ehsanul Haque Siam</title>
    <meta name="robots" content="noindex, follow" />
    <link rel="canonical" href={siteUrl + '/'} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <style is:inline>
      :root {
        --paper: #05060a;
        --paper-raised: #0b0d14;
        --ink: #eef1f8;
        --ink-muted: #8b92a8;
        --ink-faint: #6e7488;
        --hairline: rgba(235, 240, 255, 0.12);
        --vermilion: #8b7cff;
        --serif: Georgia, 'Times New Roman', serif;
        --mono: ui-monospace, SFMono-Regular, Menlo, Consolas, 'Liberation Mono', monospace;
      }
      * { box-sizing: border-box; }
      body {
        margin: 0;
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 2rem 1.25rem;
        background:
          radial-gradient(42% 34% at 70% 0%, rgba(139, 124, 255, 0.1), transparent 70%)
          var(--paper);
        color: var(--ink);
        font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
        line-height: 1.6;
      }
      main {
        width: 100%;
        max-width: 40rem;
      }
      .folio {
        display: flex;
        justify-content: space-between;
        align-items: baseline;
        gap: 1rem;
        border-top: 1px solid var(--hairline);
        padding-top: 0.75rem;
        font-family: var(--mono);
        font-size: 0.6875rem;
        letter-spacing: 0.16em;
        text-transform: uppercase;
        color: var(--ink-muted);
      }
      .folio strong { color: var(--ink); font-weight: 600; }
      .display {
        position: relative;
        margin: 1.25rem 0 0;
      }
      .giant {
        margin: 0;
        font-family: var(--serif);
        font-weight: 400;
        font-size: clamp(7rem, 30vw, 13rem);
        line-height: 0.9;
        letter-spacing: -0.03em;
        color: var(--ink);
      }
      .stamp {
        position: absolute;
        top: 14%;
        right: 0;
        transform: rotate(-4deg);
        font-family: var(--mono);
        font-size: 0.75rem;
        font-weight: 600;
        letter-spacing: 0.22em;
        text-transform: uppercase;
        color: var(--vermilion);
        border: 1px solid rgba(139, 124, 255, 0.4);
        border-radius: 999px;
        padding: 0.5rem 1rem;
        background: rgba(139, 124, 255, 0.08);
        box-shadow: 0 0 24px -6px rgba(139, 124, 255, 0.45), inset 0 1px 0 rgba(255, 255, 255, 0.08);
        backdrop-filter: blur(12px);
        -webkit-backdrop-filter: blur(12px);
      }
      h1 {
        margin: 1.75rem 0 0.75rem;
        font-family: var(--serif);
        font-weight: 400;
        font-size: clamp(1.5rem, 4.5vw, 2.25rem);
        line-height: 1.15;
        letter-spacing: -0.01em;
      }
      .desc {
        color: var(--ink-muted);
        max-width: 34rem;
        margin: 0 0 2rem;
      }
      .btn {
        display: inline-flex;
        align-items: center;
        gap: 0.6rem;
        min-height: 44px;
        padding: 0.85rem 1.6rem;
        background: var(--ink);
        color: var(--paper);
        border-radius: 999px;
        text-decoration: none;
        font-family: var(--mono);
        font-size: 0.75rem;
        font-weight: 600;
        letter-spacing: 0.16em;
        text-transform: uppercase;
        box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.4), 0 12px 32px -12px rgba(238, 241, 248, 0.35);
        transition: box-shadow 0.3s ease;
      }
      .btn:hover,
      .btn:focus-visible {
        box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.4), 0 0 0 1px rgba(139, 124, 255, 0.4), 0 12px 44px -10px rgba(139, 124, 255, 0.5);
      }
      .colophon {
        margin-top: 2.5rem;
        border-top: 1px solid var(--hairline);
        padding-top: 0.75rem;
        font-family: var(--mono);
        font-size: 0.625rem;
        letter-spacing: 0.16em;
        text-transform: uppercase;
        color: var(--ink-faint);
      }
    </style>
  </head>
  <body>
    <main>
      <div class="folio">
        <span><strong>Err. 404</strong> / Page not found</span>
        <span aria-hidden="true">Obsidian signal</span>
      </div>
      <div class="display">
        <p class="giant">404</p>
        <span class="stamp" aria-hidden="true">Signal lost</span>
      </div>
      <h1>This page slipped out of the signal.</h1>
      <p class="desc">
        The page you're looking for doesn't exist, but the portfolio of Ehsanul Haque Siam,
        AI Engineer &amp; Full-Stack Developer, is one click away.
      </p>
      <a class="btn" href="/">&larr; Return to the front page</a>
      <div class="colophon">Ehsanul Haque Siam · Dhaka, Bangladesh</div>
    </main>
  </body>
</html>
