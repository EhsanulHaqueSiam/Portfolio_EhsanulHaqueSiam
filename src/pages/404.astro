---
const siteUrl = 'https://ehsanulhaquesiam.netlify.app';
---

<!doctype html>
<html lang="en" style="background:#0a0a0f">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>404 — Page Not Found | Ehsanul Haque Siam</title>
    <meta name="robots" content="noindex, follow" />
    <link rel="canonical" href={siteUrl + '/'} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body
    style="background:#0a0a0f;color:#e5e7eb;font-family:system-ui,-apple-system,sans-serif;min-height:100vh;display:flex;align-items:center;justify-content:center;margin:0;padding:2rem;text-align:center"
  >
    <main>
      <p style="font-size:5rem;font-weight:700;margin:0;background:linear-gradient(135deg,#a78bfa,#f59e0b);-webkit-background-clip:text;background-clip:text;-webkit-text-fill-color:transparent">
        404
      </p>
      <h1 style="font-size:1.5rem;margin:0.5rem 0 1rem">This page wandered off.</h1>
      <p style="color:#9ca3af;max-width:32rem;margin:0 auto 2rem">
        The page you're looking for doesn't exist — but the portfolio of Ehsanul Haque Siam,
        AI Engineer &amp; Full-Stack Developer, is one click away.
      </p>
      <a
        href="/"
        style="display:inline-block;padding:0.75rem 1.75rem;background:#7c3aed;color:#fff;border-radius:0.75rem;text-decoration:none;font-weight:600"
      >
        ← Back to home
      </a>
    </main>
  </body>
</html>
